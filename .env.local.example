DATABASE_URL="postgresql://postgres:password@localhost:5432/checkin"

# Strong random secret used to sign JWT session cookies. Use at least 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters

# Resend credentials used for magic-link and check-in emails.
RESEND_API_KEY=replace-with-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Optional override for check-in notifications during testing.
CHECKIN_NOTIFICATION_RECIPIENT=

# Optional override for magic-link emails during testing. Leave blank in production.
MAGIC_LINK_EMAIL_RECIPIENT=

# PIN required to open/close the kiosk. Change this to a secure value before real deployment.
ADMIN_PIN=replace-with-secure-admin-pin
