// Purpose: Defines the Prisma data model, enums, and database relations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// code is a 4-digit numeric string (e.g. "3847").
// expiresAt is 10 minutes from creation.
// usedAt is set when the code is successfully verified — a code can only be used once.
// attempts tracks how many times a wrong code was entered — lock out after 5 failed attempts to prevent brute force.
model OtpCode {
  id        String    @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  createdAt DateTime  @default(now())

  @@index([email])
}

// Guests are never created as User records; this standalone log table is separate from authenticated User/Booking/Checkin flows.
model Guest {
  id        String   @id @default(cuid())
  name      String
  email     String
  purpose   String
  visitedAt DateTime @default(now())
}

// The app treats KioskStatus as a singleton. A SQL check constraint enforces id = "singleton".
model KioskStatus {
  id        String    @id @default(cuid())
  isOpen    Boolean   @default(false)
  openedAt  DateTime?
  closedAt  DateTime?
  openedBy  String?
  closedBy  String?
  updatedAt DateTime  @updatedAt
}

model AppSetting {
  id           String   @id
  adminPinHash String
  adminPinSalt String
  updatedAt    DateTime @updatedAt
}

model Shift {
  id         String    @id @default(cuid())
  // References OS4 users.id (Int) — validated at application level
  mentorId   Int
  clockInAt  DateTime  @default(now())
  clockOutAt DateTime?
  createdAt  DateTime  @default(now())

  // A SQL partial unique index allows only one active shift per mentor.
}

model Checkin {
  id          String   @id @default(cuid())
  // References OS4 bookings.id (Int) — validated at application level
  bookingId   Int      @unique
  checkedInAt DateTime @default(now())
}
