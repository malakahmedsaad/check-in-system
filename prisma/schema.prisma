generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  mentor
}

enum MentorType {
  CONSULTATION
  LAB
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id         String      @id @default(cuid())
  email      String      @unique
  name       String
  role       Role
  isAdmin    Boolean     @default(false)
  mentorType MentorType?
  createdAt  DateTime    @default(now())

  timeslots         Timeslot[]
  bookingsAsStudent Booking[]  @relation("StudentBookings")
  bookingsAsMentor  Booking[]  @relation("MentorBookings")
  shifts            Shift[]
}

// The app treats KioskStatus as a singleton by always upserting the row with id "singleton".
model KioskStatus {
  id        String    @id @default(cuid())
  isOpen    Boolean   @default(false)
  openedAt  DateTime?
  closedAt  DateTime?
  openedBy  String?
  closedBy  String?
  updatedAt DateTime  @updatedAt
}

model Shift {
  id         String    @id @default(cuid())
  mentorId   String
  clockInAt  DateTime  @default(now())
  clockOutAt DateTime?
  createdAt  DateTime  @default(now())

  mentor User @relation(fields: [mentorId], references: [id])
}

model Timeslot {
  id        String   @id @default(cuid())
  mentorId  String
  date      DateTime
  startTime DateTime
  endTime   DateTime

  mentor   User      @relation(fields: [mentorId], references: [id])
  bookings Booking[]
}

model Booking {
  id         String        @id @default(cuid())
  studentId  String
  mentorId   String
  timeslotId String
  startDate  DateTime
  endDate    DateTime
  status     BookingStatus
  createdAt  DateTime      @default(now())

  student  User     @relation("StudentBookings", fields: [studentId], references: [id])
  mentor   User     @relation("MentorBookings", fields: [mentorId], references: [id])
  timeslot Timeslot @relation(fields: [timeslotId], references: [id])
  checkin  Checkin?
}

model Checkin {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  checkedInAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
}
